<header>
 <nav style="
          --bg: {{ nav.header.metafields.custom.theme_bg }};
          --text: {{ nav.header.metafields.custom.theme_text }};
          --accent: {{ nav.header.metafields.custom.theme_accent }};
        ">
 <a href="{{ nav.header.logo.url }}" class="logo">
    <img
      src="{{ nav.header.logo.image }}"
      alt="{{ nav.header.logo.alt }}"
      class="nav-logo"
      width="260"
      height="78"
      style="display:block;width:260px;height:auto;object-fit:contain;"
    >
    </a>

 
    <ul>
      {% for item in nav.header.navigation %}
        <li>
          <a href="{{ item.url }}" 
             {% if item.url == page.url %} class="active"{% endif %}  data-barba-prevent="self">
             {{ item.label }}
          </a>
        </li>
      {% endfor %}
    </ul>
  </nav>
</header>