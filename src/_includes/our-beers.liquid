{%- assign featured_product = products | where: "handle", "lakefront-linger-sour" | first -%}

<section class="beers-section" id="products" style="
--bg: {{ featured_product.metafields.custom.theme_bg }};
--text: {{ featured_product.metafields.custom.theme_text }};
--accent: {{ featured_product.metafields.custom.theme_accent }};
">
  <div class="container">
    <h2 class="beers-section__title">OUR BEERS</h2>

    <div class="beers-grid">
      {% for product in products %}
        {%- assign can_class = "lime" -%}
        {%- case forloop.index0 -%}
          {%- when 1 -%}{%- assign can_class = "citrus" -%}
          {%- when 2 -%}{%- assign can_class = "pale" -%}
          {%- when 3 -%}{%- assign can_class = "amber" -%}
        {%- endcase -%}

        {%- assign title_words = product.title | split: ' ' -%}
        {%- assign can_line_one = title_words[0] | default: product.title -%}
        {%- assign can_line_two = title_words[1] | default: '' -%}

        <a class="beers-card" href="/products/{{ product.handle }}/" aria-label="View {{ product.title }}">
          <div class="beers-card__can beers-card__can--{{ can_class }}">
            <img
              class="beers-card__image"
              src="{{ product.featured_image }}"
              alt="{{ product.title }}"
              loading="lazy"
            >
          </div>
          <h3 class="beers-card__name">{{ product.title }}</h3>
          <p class="beers-card__abv">{{ product.abv }} ABV</p>
          <p class="beers-card__description">
            {%- for note in product.metafields.custom.flavor_notes -%}
              {{ note | upcase }}{%- unless forloop.last -%} • {% endunless %}
            {%- endfor -%}
          </p>
        </a>
      {% endfor %}
    </div>
  </div>
</section>