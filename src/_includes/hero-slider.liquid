<section
  class="hero-slider"
  data-hero-slider
  data-barba="container"
  data-barba-namespace="home"
  style="background:#B0E8DE;"
>
  <div class="hero-slider__wrapper">
    {% for product in products %}
      {% if product.handle == 'lakefront-linger-sour' %}
      <article
        class="hero-slide gsap-slide"
        data-handle="{{ product.handle }}"
        style="
          --bg: {{ product.metafields.custom.theme_bg }};
          --text: {{ product.metafields.custom.theme_text }};
          --accent: {{ product.metafields.custom.theme_accent }};
        "
      >
        <div class="hero-container">
          <div class="hero-title-wrapper gsap-title">
            <h1 class="hero-title">
              {% assign title_words = product.title | split: ' ' %}
              <span class="hero-title__line">{{ title_words[0] }}</span>
              <span class="hero-title__line">{{ title_words[1] }} {{ title_words[2] }}</span>
            </h1>
          </div>

          <div class="hero-grid">
            <div class="hero-abv-wrapper gsap-fade-in">
              <p class="hero-abv">
                <span class="hero-abv__value">{{ product.abv }}</span>
                <span class="hero-abv__label">ABV</span>
              </p>
            </div>

            <div class="hero-media gsap-fade-in">
              <img
                src="{{ product.featured_image }}"
                alt="{{ product.title }}"
                loading="eager"
              >
            </div>

            <div class="hero-meta gsap-fade-in">
              {%- if product.metafields.custom.flavor_notes.size > 0 -%}
                <p class="hero-flavor">
                  {%- for note in product.metafields.custom.flavor_notes -%}
                    {{ note | upcase }}{%- unless forloop.last -%} &bull; {% endunless %}
                  {%- endfor -%}
                </p>
              {%- endif -%}

              <a href="/products/{{ product.handle }}/" class="hero-btn">
                Explore Beers
              </a>
            </div>
          </div>
        </div>
      </article>
      {% endif %}
    {% endfor %}
  </div>
</section>
