<section id="testimonials" class="testimonials-section">

    {% assign headings = testimonials.section.title | split: "," %}
    {% assign classes = "first-title,sec-title,third-title" | split: "," %}

    <div class="testimonials-titles">

        {% for heading in headings %}

            <h2
                class="t-title {{ classes[forloop.index0] }}"
                {% if forloop.first %}id="testimonials-heading"{% endif %}
            >
                {{ heading | strip }}
            </h2>

        {% endfor %}

    </div>

    <div class="pin-box">

        {% assign total = testimonials.section.testimonials.size %}
        {% assign middle = total | divided_by: 2 %}

        {% for t in testimonials.section.testimonials %}

            {% assign offset = forloop.index0 | minus: middle %}

            <article
                class="vd-card"
                style="
                    --x: {{ offset | times: 180 }}px;
                    --r: {{ offset | times: 7 }}deg;
                ">

                <img
                    class="testimonial-image"
                    src="{{ t.image }}"
                    alt="{{ t.author }}">

                <div class="card-overlay">

                    <p class="card-quote">
                        "{{ t.quote }}"
                    </p>

                    <p class="card-author">
                        {{ t.author }} • {{ t.location }}
                    </p>

                    <p class="card-beer">
                        {{ t.beer }}
                    </p>

                </div>

            </article>

        {% endfor %}

    </div>

</section>